# ── Environment & Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production

# ── Python Backend ────────────────────────────────────────────────────────────
backend/venv/
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
backend/.pytest_cache/
backend/htmlcov/
backend/.coverage

# ── Database & Sensitive Data ─────────────────────────────────────────────────
data/db/
data/models/
data/backups/
*.db
*.db-shm
*.db-wal
*.salt

