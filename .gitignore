*.jks
*.keystore
*.p8
*.p12
*.key
*.mobileprovision
*.pem
release.keystore
upload-keystore.jks

# ── Build Outputs ─────────────────────────────────────────────────────────────
*.apk
*.aab
build/
android/app/build/

# ── EAS / Expo ────────────────────────────────────────────────────────────────
.easignore

# ── TypeScript ────────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Debug Logs ────────────────────────────────────────────────────────────────
npm-debug.*
yarn-debug.*
yarn-error.*

# ── macOS ─────────────────────────────────────────────────────────────────────
