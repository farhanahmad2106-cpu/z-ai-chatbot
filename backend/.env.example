# Z-AI Chatbot — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Z-AI Chatbot"
APP_VERSION="1.0.0"
DEBUG=false

# ── Server ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765

# ── Security — CHANGE THESE BEFORE RUNNING ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_BEFORE_PRODUCTION_CHANGE_ME_BEFORE_PRODUCTION_32

# Generate your admin key with:
# python -c "from app.core.security import generate_admin_key; print(generate_admin_key())"
ADMIN_API_KEY=CHANGE_ME_ADMIN_KEY_CHANGE_ME_ADMIN_KEY_CHANGE_ME_64_CHARS

# ── Database ──────────────────────────────────────────────────────────────────
# Leave empty to use default (data/db/z_chat.db)
# DB_PATH=

# ── AI Models ─────────────────────────────────────────────────────────────────
DEFAULT_MODEL=phi-3-mini-4k-instruct-q4.gguf
FALLBACK_MODEL=gemma-2b-it-q4_k_m.gguf
MODEL_CONTEXT_LENGTH=4096
MODEL_MAX_TOKENS=2048
MODEL_TEMPERATURE=0.7
MODEL_THREADS=4

# ── Metrics ───────────────────────────────────────────────────────────────────
METRICS_POLL_INTERVAL_SECONDS=2.0

# ── Backups ───────────────────────────────────────────────────────────────────
BACKUP_SCHEDULE_CRON="0 3 * * *"
BACKUP_RETENTION_DAYS=30
